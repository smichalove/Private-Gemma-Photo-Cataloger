# General Configuration
# Comma-separated list of directories to scan (e.g., C:\Pictures,D:\Patreon)
PICTURE_DIRECTORIES=

# Path to the photo descriptions JSON database output file
OUTPUT_DATABASE_PATH=photo_descriptions.json

# Path to the photo descriptions SQLite database output file
OUTPUT_DATABASE_SQLITE=local/photo_catalog.db

# Path to the tracking cache file that tracks processed/submitted images
SUBMITTED_CACHE_PATH=submitted_photos_cache.txt

# Path to the ExifTool executable. Defaults to "exiftool" if installed in system PATH.
EXIFTOOL_PATH=exiftool

# Option B: Local Offline Gemma 4 VLM
# Hugging Face token (only required if you need to authenticate to download model weights,
# but note the pipeline runs strictly offline HF_HUB_OFFLINE=1 once weights are cached).
HF_TOKEN=
